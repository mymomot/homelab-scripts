# Caddyfile — maps.lab.mymomot.ovh static assets
# LAN only bind (Traefik LXC 410 fait TLS termination)
# Council Art.15 bis C4 — pas d'exposition Internet directe

http://192.168.10.98:8081 {
    root * /var/www/maps
    encode gzip zstd
    file_server

    # Cache headers : assets immutables (vendor + sprites + fonts)
    @vendor path /vendor/* /sprites/* /fonts/*
    header @vendor Cache-Control "public, max-age=31536000, immutable"

    # Cache court pour HTML + style.json (itération possible)
    @html path *.html *.json
    header @html Cache-Control "public, max-age=300"

    # Logs format JSON
    log {
        output file /var/log/caddy/access.log {
            roll_size 10mb
            roll_keep 5
        }
        format json
    }
}
